---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-columns">
			<div class="footer-col">
				<p class="footer-col-heading">Navigate</p>
				<ul>
					<li><a href="/tags/">Tags</a></li>
					<li><a href="/archive/">Archive</a></li>
					<li><a href="/search/">Search</a></li>
					<li><a href="/feedback/">Feedback</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<p class="footer-col-heading">Finance</p>
				<ul>
					<li><a href="/etf/">ETF</a></li>
					<li><a href="/economics/">Economics</a></li>
					<li><a href="/market-brief/">Market Brief</a></li>
					<li><a href="/reports/">AI Research</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<p class="footer-col-heading">Computing</p>
				<ul>
					<li><a href="/cs/">Computer Science</a></li>
					<li><a href="/programming/">Programming</a></li>
					<li><a href="/semiconductor/">Semiconductor</a></li>
					<li><a href="/problem-solving/">Problem Solving</a></li>
				</ul>
			</div>
		</div>
		<div class="footer-bottom">
			<div class="social-links" aria-label="Social links">
				<a href="/rss.xml" aria-label="RSS feed">
					<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
						<path fill="currentColor" d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0ZM2 8.8v3.18c5.52 0 10.02 4.5 10.02 10.02h3.18C15.2 14.72 9.28 8.8 2 8.8Zm0-6.8v3.18c9.28 0 16.82 7.54 16.82 16.82H22C22 10.95 13.05 2 2 2Z"></path>
					</svg>
				</a>
				<a href="https://blog.naver.com/chocobreeze" target="_blank" rel="noopener noreferrer" aria-label="Naver Blog">
					<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
						<path fill="currentColor" d="M16.273 12.845L7.376 0H0v24h7.727V11.155L16.624 24H24V0h-7.727v12.845z"></path>
					</svg>
				</a>
				<a href="https://github.com/ChocoBreeze" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
					<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
						<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
					</svg>
				</a>
			</div>
			<p class="copyright">&copy; {today.getFullYear()} 정영훈. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		background: var(--nv-surface-dark);
		color: var(--nv-on-dark-mute);
	}
	.footer-inner {
		max-width: 1280px;
		margin: 0 auto;
		padding: 64px 48px;
	}
	.footer-columns {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 2rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--nv-hairline-strong);
		margin-bottom: 2rem;
	}
	.footer-col-heading {
		margin: 0 0 1rem;
		font-size: 15px;
		font-weight: 700;
		color: var(--nv-on-dark);
	}
	.footer-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.6rem;
	}
	.footer-col a {
		color: var(--nv-on-dark-mute);
		text-decoration: none;
		font-size: 15px;
		transition: color 0.2s ease;
	}
	.footer-col a:hover {
		color: var(--nv-primary);
	}
	.footer-col a:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--nv-primary) 60%, transparent);
		outline-offset: 3px;
		border-radius: var(--nv-radius-sm);
	}
	.footer-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--nv-on-dark-mute);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: var(--nv-primary);
	}
	.social-links a:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--nv-primary) 60%, transparent);
		outline-offset: 3px;
		border-radius: var(--nv-radius-sm);
	}
	.copyright {
		margin: 0;
		font-size: 12px;
		color: var(--nv-on-dark-mute);
	}
	@media (max-width: 768px) {
		.footer-inner {
			padding: 48px 24px;
		}
		.footer-columns {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	@media (max-width: 480px) {
		.footer-inner {
			padding: 32px 16px;
		}
		.footer-columns {
			grid-template-columns: 1fr;
		}
		.footer-bottom {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
