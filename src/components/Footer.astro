---
const today = new Date();
---

<footer>
	<p class="copyright">&copy; {today.getFullYear()} 정영훈. All rights reserved.</p>
	<div class="social-links" aria-label="Social links">
		<a href="https://blog.naver.com/chocobreeze" target="_blank" rel="noopener noreferrer" class="naver-link">
			<span class="sr-only">Follow me on Naver Blog</span>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32"
				><path
					fill="currentColor"
					d="M16.273 12.845L7.376 0H0v24h7.727V11.155L16.624 24H24V0h-7.727v12.845z"
				></path></svg
			>
		</a>
		<a href="https://github.com/ChocoBreeze" target="_blank" rel="noopener noreferrer">
			<span class="sr-only">Go to my GitHub profile</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="36" height="36"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 5em;
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--card-bg) 72%, transparent), var(--bg-color)) no-repeat;
		border-top: 1px solid var(--border-color);
		color: var(--muted-text);
		text-align: center;
	}
	.copyright {
		margin: 0;
		color: var(--muted-text);
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
		align-items: center;
	}
	.social-links a {
		text-decoration: none;
		color: var(--muted-text);
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		transition: color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
	}
	.social-links a:hover {
		color: var(--accent);
		transform: translateY(-2px);
	}
	.social-links a:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--accent) 45%, transparent);
		outline-offset: 4px;
	}
	.social-links a.naver-link {
		color: #03c75a;
	}
	.social-links a.naver-link:hover {
		color: #02b350;
	}
</style>
