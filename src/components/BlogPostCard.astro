---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

type Props = {
	post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const date = post.data.pubDate || post.data.date;
const image = post.data.heroImage || (post.data.image ? `/images/${post.data.image}` : undefined);
const href = `/blog/${post.data.slug || post.id}/`;
const topics = post.data.topics?.slice(0, 3) ?? [];
---

<li class={`blog-post-card${image ? '' : ' no-image'}`} data-pub-date={date ? new Date(date).getTime().toString() : '0'} data-difficulty={post.data.difficulty ?? ''}>
	<a href={href}>
		{
			image && (
				<img width={720} height={360} src={image} alt="" loading="lazy" />
			)
		}
		<div class="blog-post-card-body">
			<h2 class="title">{post.data.title}</h2>
			{
				(post.data.difficulty || topics.length > 0) && (
					<div class="post-meta-chips" aria-label="Post metadata">
						{post.data.difficulty && (
							<span class={`post-meta-chip difficulty-${post.data.difficulty.toLowerCase()}`}>
								{post.data.difficulty}
							</span>
						)}
						{topics.map((topic) => (
							<span class="post-meta-chip">{topic}</span>
						))}
					</div>
				)
			}
			{post.data.description && <p class="excerpt">{post.data.description}</p>}
			{
				date && (
					<p class="date">
						<FormattedDate date={date} />
					</p>
				)
			}
		</div>
	</a>
</li>
