---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { normalizeCategory } from '../../data/blogCategories';

const posts = await getCollection('blog');
const categoryCounts = new Map<string, number>();

for (const post of posts) {
	const categories = Array.isArray(post.data.categories) ? post.data.categories : [post.data.categories];
	for (const category of categories) {
		const normalized = normalizeCategory(category);
		if (!normalized) continue;
		categoryCounts.set(normalized, (categoryCounts.get(normalized) ?? 0) + 1);
	}
}

const sections = [
	{
		key: 'ETF',
		href: '/etf',
		icon: '📈',
		title: 'ETF',
		description: 'ETF 구조, 상품 비교, 투자 아이디어를 축적합니다.',
	},
	{
		key: 'Reports',
		href: '/reports',
		icon: '🤖',
		title: 'AI Research',
		description: 'AI를 활용해 기업, 산업, 기술 주제를 리포트형으로 깊게 조사합니다.',
	},
	{
		key: 'Market Brief',
		href: '/market-brief',
		icon: '📊',
		title: 'Market Brief',
		description: '전일과 전주의 미국 시장 흐름을 짧고 밀도 있게 정리합니다.',
	},
	{
		key: 'Economics',
		href: '/economics',
		icon: '🌐',
		title: 'Economics',
		description: '시장 해석에 필요한 경제 개념과 매크로 구조를 체계적으로 정리합니다.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Finance"
			description="ETF, AI Research, Market Brief, Economics를 묶는 상위 섹션입니다."
		/>
	</head>
	<body>
		<Header />
		<main class="finance-page">
			<section class="finance-hero">
				<p class="eyebrow">Finance</p>
				<h1>Finance</h1>
				<p class="description">
					상품 분석, 시장 요약, 경제 개념, 리서치 리포트를 하나의 흐름으로 연결해 정리합니다.
				</p>
			</section>

			<section class="finance-grid" aria-label="Finance sections">
				{
					sections.map((section) => (
						<a href={section.href} class="finance-card">
							<span class="icon">{section.icon}</span>
							<div class="card-header">
								<h2>{section.title}</h2>
								<p class="count">{categoryCounts.get(section.key) ?? 0} posts</p>
							</div>
							<p>{section.description}</p>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.finance-page {
		width: min(1100px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 4rem 0 5rem;
	}

	.finance-hero {
		margin-bottom: 2.5rem;
		padding: 2.5rem;
		border-radius: 28px;
		background:
			radial-gradient(circle at top left, rgba(245, 158, 11, 0.18), transparent 32%),
			radial-gradient(circle at top right, rgba(16, 185, 129, 0.16), transparent 30%),
			linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 250, 240, 0.96));
		box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
	}

	h1 {
		margin: 0;
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		line-height: 0.95;
	}

	.description {
		max-width: 42rem;
		margin: 1rem 0 0;
		font-size: 1.1rem;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
	}

	.finance-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.finance-card {
		display: block;
		padding: 1.75rem;
		border-radius: 22px;
		background: white;
		color: inherit;
		text-decoration: none;
		border: 1px solid rgba(15, 23, 42, 0.08);
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.05);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease,
			border-color 0.25s ease;
	}

	.finance-card:hover {
		transform: translateY(-6px);
		border-color: color-mix(in srgb, var(--accent) 35%, transparent);
		box-shadow: 0 24px 48px rgba(15, 23, 42, 0.09);
	}

	.icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		margin-bottom: 1rem;
		font-size: 1.6rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--accent) 12%, white);
	}

	.card-header {
		display: grid;
		gap: 0.45rem;
		margin-bottom: 0.75rem;
	}

	h2 {
		margin: 0;
		font-size: 1.3rem;
	}

	.count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		margin: 0;
		padding: 0.35rem 0.7rem;
		border-radius: 999px;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 12%, white);
		border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
	}

	.finance-card p {
		margin: 0;
		line-height: 1.6;
		color: rgb(var(--gray-dark));
	}

	@media (max-width: 900px) {
		.finance-grid {
			grid-template-columns: 1fr;
		}

		.finance-hero {
			padding: 2rem;
		}
	}
</style>
