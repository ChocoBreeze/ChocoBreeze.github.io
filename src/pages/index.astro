---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 900px;
				margin: 0 auto;
				padding: 4em 1em;
				text-align: center;
			}
			.hero-section {
				margin-bottom: 4rem;
			}
			.profile-container {
				margin-bottom: 1.5rem;
			}
			.profile-image {
				width: 180px;
				height: 180px;
				border-radius: 50%;
				object-fit: cover;
				border: 5px solid var(--card-bg);
				box-shadow: 0 10px 25px rgba(0,0,0,0.1);
				transition: transform 0.3s ease;
			}
			.profile-image:hover {
				transform: scale(1.05);
			}
			h1 {
				font-size: 3.5rem;
				margin-bottom: 0.5rem;
				background: linear-gradient(45deg, var(--accent), #7232f2);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				font-weight: 800;
			}
			.description {
				font-size: 1.4rem;
				color: var(--muted-text);
				margin-bottom: 3rem;
				font-weight: 500;
			}
			
			.features-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.5rem;
				margin-bottom: 4rem;
			}
			.feature-card {
				background: var(--card-bg);
				padding: 2rem 1.5rem;
				border-radius: 16px;
				box-shadow: 0 4px 15px rgba(0,0,0,0.05);
				transition: all 0.3s ease;
				text-decoration: none;
				color: var(--text-color);
				border: 1px solid var(--border-color);
			}
			.feature-card:hover {
				transform: translateY(-10px);
				box-shadow: 0 12px 30px rgba(0,0,0,0.1);
				border-color: var(--accent);
			}
			.feature-card .icon {
				font-size: 2.5rem;
				margin-bottom: 1rem;
				display: block;
			}
			.feature-card h3 {
				margin: 0 0 0.5rem 0;
				font-size: 1.25rem;
				color: var(--heading-color);
			}
			.feature-card p {
				margin: 0;
				font-size: 0.9rem;
				color: var(--muted-text);
				line-height: 1.4;
			}

			.goals-section {
				background: color-mix(in srgb, var(--card-bg) 82%, transparent);
				backdrop-filter: blur(10px);
				padding: 3rem;
				border-radius: 24px;
				text-align: left;
				box-shadow: 0 4px 20px rgba(0,0,0,0.03);
				border: 1px solid var(--border-color);
			}
			.goals-section h2 {
				font-size: 2rem;
				margin-top: 0;
				margin-bottom: 1.5rem;
				border: none;
				color: var(--accent);
			}
			.goals-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
			}
			.goals-list li {
				padding: 1rem;
				background: var(--card-bg);
				border-radius: 12px;
				font-weight: 500;
				display: flex;
				align-items: center;
				box-shadow: 0 2px 8px rgba(0,0,0,0.02);
				color: var(--text-color);
			}
			.goals-list li::before {
				content: "✨";
				margin-right: 0.75rem;
			}

			@media (max-width: 768px) {
\t\t\t\t.features-grid {
					grid-template-columns: 1fr;
				}
				.goals-list {
					grid-template-columns: 1fr;
				}
				h1 { font-size: 2.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero-section">
				<div class="profile-container">
					<img src="/images/Mine/Home.png" alt="ChocoBreeze" class="profile-image" />
				</div>
				<h1>ChocoBreeze</h1>
				<p class="description">
					이유를 고민하고 성장을 기록하는 정영훈의 블로그입니다.
				</p>
			</div>

			<div class="features-grid">
				<a href="/finance" class="feature-card">
					<span class="icon">📈</span>
					<h3>Finance</h3>
					<p>ETF, AI Research, Market Brief, 경제 개념을 하나의 흐름으로 묶어 정리합니다.</p>
				</a>
				<a href="/semiconductor" class="feature-card">
					<span class="icon">🔬</span>
					<h3>Semiconductor</h3>
					<p>반도체 기초부터 구조와 산업 흐름까지 차근차근 정리합니다.</p>
				</a>
				<a href="/computing" class="feature-card">
					<span class="icon">🧠</span>
					<h3>Computing</h3>
					<p>Computer Science, Programming, Problem Solving을 하나의 흐름으로 묶습니다.</p>
				</a>
			</div>
			
			<div class="goals-section">
				<h2>나의 다짐 (Goals)</h2>
				<ul class="goals-list">
					<li>끼니 거르지 않기</li>
					<li>이유 생각하기</li>
					<li>다양한 기술 탐구하기</li>
					<li>기록을 멈추지 않기</li>
				</ul>
			</div>
		</main>
		<Footer />
	</body>
</html>
