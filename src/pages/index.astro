---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 800px;
				margin: 0 auto;
				padding: 3em 1em;
				text-align: center;
			}
			.profile-container {
				margin-bottom: 2rem;
			}
			.profile-image {
				width: 150px;
				height: 150px;
				border-radius: 50%;
				object-fit: cover;
				border: 4px solid var(--accent);
				box-shadow: var(--box-shadow);
			}
			h1 {
				font-size: 3rem;
				margin-bottom: 0.5rem;
			}
			.description {
				font-size: 1.25rem;
				color: rgb(var(--gray-dark));
				margin-bottom: 2rem;
			}
			.goals {
				text-align: left;
				display: inline-block;
				background: #f8f9fa;
				padding: 1.5rem 2rem;
				border-radius: 12px;
				border-left: 5px solid #7232f2; /* Astro accent color */
			}
			.goals h2 {
				font-size: 1.5rem;
				margin-top: 0;
			}
			.goals ul {
				margin: 0;
				padding-left: 1.2rem;
			}
			.goals li {
				margin-bottom: 0.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="profile-container">
				<img src="/images/Okeydokey/pic_62.jpg" alt="ChocoBreeze" class="profile-image" />
			</div>
			<h1>👨‍💻 {SITE_TITLE}</h1>
			<p class="description">
				{SITE_DESCRIPTION}
			</p>
			
			<div class="goals">
				<h2>나의 다짐</h2>
				<ul>
					<li>너무 늦게 자지 않기</li>
					<li>끼니 거르지 않기</li>
					<li>이유 생각하기 (Why?)</li>
					<li>알고리즘을 넘어 다양한 기술 탐구하기</li>
				</ul>
			</div>
			
			<p style="margin-top: 3rem;">
				지금까지의 공부 기록은 <a href="/problem-solving">Problem Solving</a> 메뉴에서 확인할 수 있습니다.
			</p>
		</main>
		<Footer />
	</body>
</html>
