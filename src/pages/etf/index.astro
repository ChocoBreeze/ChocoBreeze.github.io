---
import { getCollection } from 'astro:content';
import { BLOG_CATEGORIES } from '../../data/blogCategories';
import BlogListLayout from '../../layouts/BlogListLayout.astro';

const posts = (await getCollection('blog'))
	.filter((post) => {
		const cats = post.data.categories;
		return Array.isArray(cats) ? cats.includes('ETF') : cats === 'ETF';
	})
	.sort((a, b) => {
		if (a.data.pinned && !b.data.pinned) return -1;
		if (!a.data.pinned && b.data.pinned) return 1;

		if (a.data.order !== undefined && b.data.order !== undefined) {
			return a.data.order - b.data.order;
		}

		const dateA = a.data.pubDate || a.data.date || new Date(0);
		const dateB = b.data.pubDate || b.data.date || new Date(0);
		return dateA.valueOf() - dateB.valueOf();
	});

const category = BLOG_CATEGORIES.find(({ key }) => key === 'ETF')!;

const etfSections = Array.from(
	posts.reduce((sections, post) => {
		const pathParts = post.id.replaceAll('\\', '/').split('/');
		if (pathParts[0] !== 'ETF' || pathParts.length < 3) {
			return sections;
		}

		const section = pathParts[1];
		const subPath = pathParts.slice(2, -1).join('/');
		const ticker = pathParts.length > 3 ? pathParts[pathParts.length - 2] : undefined;
		const href = `/blog/${post.data.slug || post.id}/`;
		const entry = {
			title: post.data.title,
			href,
			subPath: subPath || section,
			ticker,
		};

		const current = sections.get(section) ?? [];
		current.push(entry);
		sections.set(section, current);
		return sections;
	}, new Map<string, { title: string; href: string; subPath: string; ticker?: string }[]>())
)
	.map(([section, entries]) => ({
		section,
		entries: entries.sort((a, b) => a.title.localeCompare(b.title, 'en')),
	}))
	.sort((a, b) => a.section.localeCompare(b.section, 'en'));
---

<BlogListLayout
	title={category.title}
	description={category.description}
	activeCategory={category.key}
	posts={posts}
>
	<section class="etf-classification-index" aria-labelledby="etf-classification-heading">
		<div class="etf-classification-heading">
			<p class="section-eyebrow">ETF Classification</p>
			<h2 id="etf-classification-heading">분류별 ETF 빠른 탐색</h2>
			<p>
				ETF 글은 운용 목적과 노출 자산에 따라 물리 폴더를 나눠 정리합니다.
				아래 카드는 현재 작성된 글을 분류별로 모은 인덱스입니다.
			</p>
		</div>
		<div class="etf-section-grid">
			{
				etfSections.map(({ section, entries }) => (
					<article class="etf-section-card">
						<div class="etf-section-card-header">
							<h3>{section}</h3>
							<span>{entries.length} posts</span>
						</div>
						<ul>
							{entries.slice(0, 8).map((entry) => (
								<li>
									<a href={entry.href}>
										<strong>{entry.ticker || entry.title}</strong>
										<small>{entry.subPath}</small>
									</a>
								</li>
							))}
						</ul>
						{entries.length > 8 && <p class="more-count">+ {entries.length - 8} more in this section</p>}
					</article>
				))
			}
		</div>
	</section>
</BlogListLayout>

<style>
	.etf-classification-index {
		margin: 0 0 2.5rem;
		padding: 1.25rem;
		border: 1px solid var(--border-color);
		border-radius: 24px;
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 45%),
			color-mix(in srgb, var(--card-bg) 94%, var(--accent) 6%);
	}

	.etf-classification-heading {
		margin-bottom: 1rem;
	}

	.section-eyebrow {
		margin: 0 0 0.35rem;
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.etf-classification-heading h2 {
		margin-top: 0;
	}

	.etf-classification-heading p {
		margin: 0;
		color: var(--muted-text);
	}

	.etf-section-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.etf-section-card {
		padding: 1rem;
		border: 1px solid color-mix(in srgb, var(--border-color) 84%, var(--accent) 16%);
		border-radius: 18px;
		background: color-mix(in srgb, var(--card-bg) 96%, var(--accent) 4%);
	}

	.etf-section-card-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.etf-section-card h3 {
		margin: 0;
		font-size: 1.05rem;
	}

	.etf-section-card-header span,
	.more-count,
	.etf-section-card small {
		color: var(--muted-text);
		font-size: 0.78rem;
	}

	.etf-section-card ul {
		display: grid;
		gap: 0.45rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.etf-section-card a {
		display: grid;
		gap: 0.08rem;
		padding: 0.55rem 0.65rem;
		border-radius: 12px;
		color: var(--heading-color);
		text-decoration: none;
	}

	.etf-section-card a:hover {
		background: color-mix(in srgb, var(--accent) 10%, transparent);
	}

	.etf-section-card strong {
		font-size: 0.92rem;
	}

	.more-count {
		margin: 0.75rem 0 0;
	}
</style>
