---
import { getCollection } from 'astro:content';
import { BLOG_CATEGORIES } from '../../data/blogCategories';
import BlogListLayout from '../../layouts/BlogListLayout.astro';

const posts = (await getCollection('blog'))
	.filter((post) => {
		const cats = post.data.categories;
		return Array.isArray(cats) ? cats.includes('Programming') : cats === 'Programming';
	})
	.sort((a, b) => {
		if (a.data.pinned && !b.data.pinned) return -1;
		if (!a.data.pinned && b.data.pinned) return 1;

		if (a.data.order !== undefined && b.data.order !== undefined) {
			return a.data.order - b.data.order;
		}

		const dateA = a.data.pubDate || a.data.date || new Date(0);
		const dateB = b.data.pubDate || b.data.date || new Date(0);
		return dateB.valueOf() - dateA.valueOf();
	});

const category = BLOG_CATEGORIES.find(({ key }) => key === 'Programming')!;
---

<BlogListLayout
	title={category.title}
	description={category.description}
	activeCategory={category.key}
	posts={posts}
>
	<section class="programming-guide-card" aria-labelledby="programming-guide-heading">
		<div>
			<p class="section-eyebrow">Learning Roadmap</p>
			<h2 id="programming-guide-heading">RAG 학습 글을 순서대로 따라가려면</h2>
			<p>
				Week 1부터 Week 9까지 이어지는 RAG 실습 기록을 하나의 로드맵으로 묶었습니다.
			</p>
		</div>
		<a href="/programming/rag">RAG 로드맵 보기</a>
	</section>
</BlogListLayout>

<style>
	.programming-guide-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin: 0 0 2rem;
		padding: 1.2rem;
		border: 1px solid var(--border-color);
		border-radius: 22px;
		background:
			linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 46%),
			var(--card-bg);
	}

	.section-eyebrow {
		margin: 0 0 0.35rem;
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.programming-guide-card h2 {
		margin: 0 0 0.35rem;
		font-size: 1.25rem;
	}

	.programming-guide-card p {
		margin: 0;
		color: var(--muted-text);
	}

	.programming-guide-card a {
		flex-shrink: 0;
		padding: 0.7rem 0.9rem;
		border-radius: 999px;
		background: var(--accent);
		color: white;
		font-weight: 800;
		text-decoration: none;
	}

	@media (max-width: 760px) {
		.programming-guide-card {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
