---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Search | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 960px;
				margin: auto;
				padding: 3em 1em;
			}
			.search-container {
				margin-bottom: 2rem;
			}
			#search-input {
				width: 100%;
				padding: 0.8rem 1.2rem;
				font-size: 1.2rem;
				border: 2px solid var(--border-color);
				border-radius: 14px;
				outline: none;
				background: var(--card-bg);
				color: var(--text-color);
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			#search-input::placeholder {
				color: var(--muted-text);
			}
			#search-input:focus {
				border-color: var(--accent);
				box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent);
			}
			#results-list {
				list-style: none;
				padding: 0;
				display: grid;
				gap: 1rem;
			}
			.result-item {
				padding: 1rem;
				border-radius: 18px;
				background: var(--card-bg);
				border: 1px solid var(--border-color);
				box-shadow: 0 10px 24px rgba(var(--gray), 0.08);
				transition: background-color 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
			}
			.result-item:hover {
				background-color: color-mix(in srgb, var(--card-bg) 82%, var(--muted-text) 18%);
				border-color: color-mix(in srgb, var(--accent) 35%, var(--border-color));
				box-shadow: 0 16px 36px rgba(var(--gray), 0.14);
				transform: translateY(-2px);
			}
			.result-item a {
				display: block;
				text-decoration: none;
				color: var(--text-color);
			}
			.result-item a:focus-visible {
				outline: 3px solid color-mix(in srgb, var(--accent) 45%, transparent);
				outline-offset: 5px;
				border-radius: 12px;
			}
			.result-item h3 {
				margin: 0 0 0.5rem 0;
				color: var(--heading-color);
			}
			.result-item p {
				margin: 0;
				color: var(--muted-text);
				font-size: 0.9rem;
			}
			.result-category {
				display: inline-block;
				padding: 0.2rem 0.5rem;
				background: color-mix(in srgb, var(--card-bg) 78%, var(--muted-text) 22%);
				border: 1px solid var(--border-color);
				border-radius: 4px;
				font-size: 0.7rem;
				margin-bottom: 0.5rem;
				color: var(--muted-text);
			}
			#results-count {
				margin-bottom: 1rem;
				font-size: 0.9rem;
				color: var(--muted-text);
			}
			#results-count.error {
				color: #c2410c;
			}
			[data-theme='dark'] #results-count.error {
				color: #fb923c;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="search-container">
				<h1>검색</h1>
				<input
					type="text"
					id="search-input"
					placeholder="검색 인덱스를 불러오는 중..."
					aria-label="게시글 검색"
					aria-describedby="results-count"
					autocomplete="off"
					disabled
					autofocus
				/>
			</div>
			<div id="results-count" role="status" aria-live="polite"></div>
			<ul id="results-list"></ul>
		</main>
		<Footer />

		<script>
			type SearchItem = {
				title: string;
				description?: string;
				categories?: string | string[] | null;
				slug: string;
			};

			let searchIndex: SearchItem[] = [];
			const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
			const resultsList = document.getElementById('results-list');
			const resultsCount = document.getElementById('results-count');

			if (searchInput && resultsList && resultsCount) {
				loadSearchIndex();

				searchInput.addEventListener('input', () => {
					updateResults(searchInput.value);
				});
			}

			async function loadSearchIndex() {
				if (!searchInput || !resultsCount) return;

				try {
					const response = await fetch('/search.json', {
						headers: { Accept: 'application/json' },
					});
					if (!response.ok) {
						throw new Error(`Search index request failed: ${response.status}`);
					}

					const data: unknown = await response.json();
					if (!Array.isArray(data)) {
						throw new Error('Search index response is not an array');
					}

					searchIndex = data.filter(isSearchItem);
					searchInput.disabled = false;
					searchInput.placeholder = '제목이나 설명으로 검색하세요...';
					resultsCount.classList.remove('error');

					if (searchInput.value.trim()) {
						updateResults(searchInput.value);
					}
				} catch {
					searchInput.disabled = true;
					searchInput.placeholder = '검색을 사용할 수 없습니다.';
					resultsCount.classList.add('error');
					resultsCount.textContent = '검색 인덱스를 불러오지 못했습니다. 잠시 후 다시 시도해 주세요.';
				}
			}

			function isSearchItem(item: unknown): item is SearchItem {
				if (!item || typeof item !== 'object') return false;

				const candidate = item as Record<string, unknown>;
				return typeof candidate.title === 'string' && typeof candidate.slug === 'string';
			}

			function updateResults(value: string) {
				if (!resultsList || !resultsCount) return;

				const query = value.toLowerCase().trim();
				if (query.length < 2) {
					resultsList.replaceChildren();
					resultsCount.classList.remove('error');
					resultsCount.textContent = '';
					return;
				}

				const filtered = searchIndex.filter(item =>
					item.title.toLowerCase().includes(query) ||
					(item.description && item.description.toLowerCase().includes(query))
				);

				displayResults(filtered);
			}

			function getCategoryLabel(categories: SearchItem['categories']) {
				if (Array.isArray(categories)) return categories[0] || 'Uncategorized';
				return categories || 'Uncategorized';
			}

			function getPostHref(slug: string) {
				const normalizedSlug = slug
					.split('/')
					.filter(Boolean)
					.map((segment) => encodeURIComponent(segment))
					.join('/');

				return `/blog/${normalizedSlug}/`;
			}

			function displayResults(results: SearchItem[]) {
				if (!resultsList || !resultsCount) return;

				resultsCount.classList.remove('error');
				resultsCount.textContent = `${results.length}개의 결과를 찾았습니다.`;
				const resultItems = results.map((item) => {
					const listItem = document.createElement('li');
					listItem.className = 'result-item';

					const link = document.createElement('a');
					link.href = getPostHref(item.slug);

					const category = document.createElement('span');
					category.className = 'result-category';
					category.textContent = getCategoryLabel(item.categories);

					const title = document.createElement('h3');
					title.textContent = item.title;

					const description = document.createElement('p');
					description.textContent = item.description || '';

					link.append(category, title, description);
					listItem.append(link);

					return listItem;
				});

				resultsList.replaceChildren(...resultItems);
			}
		</script>
	</body>
</html>
