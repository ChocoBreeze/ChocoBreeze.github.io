---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { BLOG_CATEGORIES } from '../data/blogCategories';
import { getSearchCategorySlug } from '../lib/searchIndex';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Search | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 100%;
				max-width: 960px;
				margin: auto;
				padding: 3em 1em;
			}
			.search-container {
				margin-bottom: 2rem;
			}
			.search-controls {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(12rem, 16rem);
				gap: 0.75rem;
				align-items: center;
			}
			#search-input,
			#search-category {
				width: 100%;
				padding: 0.8rem 1.2rem;
				font-size: 1.2rem;
				border: 2px solid var(--border-color);
				border-radius: 14px;
				outline: none;
				background: var(--card-bg);
				color: var(--text-color);
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			#search-input::placeholder {
				color: var(--muted-text);
			}
			#search-input:focus,
			#search-category:focus {
				border-color: var(--accent);
				box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 18%, transparent);
			}
			#search-category {
				cursor: pointer;
				font-size: 1rem;
			}
			#results-list {
				list-style: none;
				padding: 0;
				display: grid;
				gap: 1rem;
			}
			.result-item {
				padding: 1rem;
				border-radius: 18px;
				background: var(--card-bg);
				border: 1px solid var(--border-color);
				box-shadow: 0 10px 24px rgba(var(--gray), 0.08);
				transition: background-color 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
			}
			.result-item:hover {
				background-color: color-mix(in srgb, var(--card-bg) 82%, var(--muted-text) 18%);
				border-color: color-mix(in srgb, var(--accent) 35%, var(--border-color));
				box-shadow: 0 16px 36px rgba(var(--gray), 0.14);
				transform: translateY(-2px);
			}
			.result-item a {
				display: block;
				text-decoration: none;
				color: var(--text-color);
			}
			.result-item a:focus-visible {
				outline: 3px solid color-mix(in srgb, var(--accent) 45%, transparent);
				outline-offset: 5px;
				border-radius: 12px;
			}
			.result-item h3 {
				margin: 0 0 0.5rem 0;
				color: var(--heading-color);
			}
			.result-item p {
				margin: 0;
				color: var(--muted-text);
				font-size: 0.9rem;
			}
			.result-snippet {
				margin-top: 0.65rem;
				padding: 0.7rem 0.85rem;
				border-left: 3px solid color-mix(in srgb, var(--accent) 65%, var(--border-color));
				border-radius: 10px;
				background: color-mix(in srgb, var(--card-bg) 88%, var(--muted-text) 12%);
				line-height: 1.6;
			}
			.result-snippet mark {
				border-radius: 0.2em;
				padding: 0.05em 0.18em;
				background: color-mix(in srgb, var(--accent) 24%, transparent);
				color: var(--heading-color);
			}
			.result-category {
				display: inline-block;
				padding: 0.2rem 0.5rem;
				background: color-mix(in srgb, var(--card-bg) 78%, var(--muted-text) 22%);
				border: 1px solid var(--border-color);
				border-radius: 4px;
				font-size: 0.7rem;
				margin-bottom: 0.5rem;
				color: var(--muted-text);
			}
			#results-count {
				margin-bottom: 1rem;
				font-size: 0.9rem;
				color: var(--muted-text);
			}
			#results-count.error {
				color: #c2410c;
			}
			[data-theme='dark'] #results-count.error {
				color: #fb923c;
			}
			@media (max-width: 640px) {
				.search-controls {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="search-container">
				<h1>검색</h1>
				<div class="search-controls">
					<input
						type="text"
						id="search-input"
						placeholder="검색 인덱스를 불러오는 중..."
						aria-label="게시글 검색"
						aria-describedby="results-count"
						autocomplete="off"
						disabled
						autofocus
					/>
					<select id="search-category" aria-label="검색 카테고리" disabled>
						<option value="/search.json">전체 카테고리</option>
						{BLOG_CATEGORIES.map((category) => (
							<option value={`/search/${getSearchCategorySlug(category.key)}.json`}>
								{category.label}
							</option>
						))}
					</select>
				</div>
			</div>
			<div id="results-count" role="status" aria-live="polite"></div>
			<ul id="results-list"></ul>
		</main>
		<Footer />

		<script>
			type SearchItem = {
				t: string;
				d?: string;
				c?: string | string[] | null;
				g?: string[];
				h?: string[];
				e?: string;
				x?: string;
				s: string;
			};

			type SearchResult = {
				item: SearchItem;
				score: number;
				snippet?: string;
			};

			let searchIndex: SearchItem[] = [];
			const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
			const searchCategory = document.getElementById('search-category') as HTMLSelectElement | null;
			const resultsList = document.getElementById('results-list');
			const resultsCount = document.getElementById('results-count');

			if (searchInput && searchCategory && resultsList && resultsCount) {
				loadSearchIndex();

				searchInput.addEventListener('input', () => {
					updateResults(searchInput.value);
				});
				searchCategory.addEventListener('change', () => {
					loadSearchIndex(searchCategory.value);
				});
			}

			async function loadSearchIndex(indexPath = '/search.json') {
				if (!searchInput || !searchCategory || !resultsCount || !resultsList) return;

				try {
					searchInput.disabled = true;
					searchCategory.disabled = true;
					searchInput.placeholder = '검색 인덱스를 불러오는 중...';
					resultsList.replaceChildren();
					resultsCount.classList.remove('error');
					resultsCount.textContent = '';

					const response = await fetch(indexPath, {
						headers: { Accept: 'application/json' },
					});
					if (!response.ok) {
						throw new Error(`Search index request failed: ${response.status}`);
					}

					const data: unknown = await response.json();
					if (!Array.isArray(data)) {
						throw new Error('Search index response is not an array');
					}

					searchIndex = data.filter(isSearchItem);
					searchInput.disabled = false;
					searchCategory.disabled = false;
					searchInput.placeholder = '제목, 설명, 태그, 소제목, 본문 요약으로 검색하세요...';
					resultsCount.classList.remove('error');

					if (searchInput.value.trim()) {
						updateResults(searchInput.value);
					}
				} catch {
					searchInput.disabled = true;
					searchCategory.disabled = false;
					searchInput.placeholder = '검색을 사용할 수 없습니다.';
					resultsCount.classList.add('error');
					resultsCount.textContent = '검색 인덱스를 불러오지 못했습니다. 잠시 후 다시 시도해 주세요.';
				}
			}

			function isSearchItem(item: unknown): item is SearchItem {
				if (!item || typeof item !== 'object') return false;

				const candidate = item as Record<string, unknown>;
				return typeof candidate.t === 'string' && typeof candidate.s === 'string';
			}

			function updateResults(value: string) {
				if (!resultsList || !resultsCount) return;

				const query = value.toLowerCase().trim();
				if (query.length < 2) {
					resultsList.replaceChildren();
					resultsCount.classList.remove('error');
					resultsCount.textContent = '';
					return;
				}

				const results = searchIndex
					.map((item) => ({
						item,
						score: getSearchScore(item, query),
						snippet: getMatchSnippet(item, query),
					}))
					.filter((result) => result.score > 0)
					.sort((a, b) => b.score - a.score);

				displayResults(results);
			}

			function includesQuery(value: string | undefined, query: string) {
				return typeof value === 'string' && value.toLowerCase().includes(query);
			}

			function getSearchScore(item: SearchItem, query: string) {
				let score = 0;

				if (includesQuery(item.t, query)) score += 60;
				if (includesQuery(item.d, query)) score += 30;
				if (includesQuery(item.e, query)) score += 12;
				if (includesQuery(item.x, query)) score += 12;

				if ((item.g ?? []).some((tag) => includesQuery(tag, query))) {
					score += 25;
				}

				if ((item.h ?? []).some((heading) => includesQuery(heading, query))) {
					score += 20;
				}

				const category = getCategoryLabel(item.c);
				if (includesQuery(category, query)) {
					score += 15;
				}

				return score;
			}

			function getMatchSnippet(item: SearchItem, query: string) {
				const sources = [
					item.d,
					...(item.h ?? []),
					item.e,
					item.x,
				];

				for (const source of sources) {
					if (!source) continue;

					const index = source.toLowerCase().indexOf(query);
					if (index === -1) continue;

					const contextLength = 90;
					const start = Math.max(0, index - contextLength);
					const end = Math.min(source.length, index + query.length + contextLength);
					const prefix = start > 0 ? '...' : '';
					const suffix = end < source.length ? '...' : '';
					return `${prefix}${source.slice(start, end).trim()}${suffix}`;
				}

				return item.d || item.e || '';
			}

			function getCategoryLabel(categories: SearchItem['c']) {
				if (Array.isArray(categories)) return categories[0] || 'Uncategorized';
				return categories || 'Uncategorized';
			}

			function getPostHref(slug: string) {
				const normalizedSlug = slug
					.split('/')
					.filter(Boolean)
					.map((segment) => encodeURIComponent(segment))
					.join('/');

				return `/blog/${normalizedSlug}/`;
			}

			function displayResults(results: SearchResult[]) {
				if (!resultsList || !resultsCount) return;

				resultsCount.classList.remove('error');
				resultsCount.textContent = `${results.length}개의 결과를 찾았습니다.`;
				const resultItems = results.map(({ item, snippet }) => {
					const listItem = document.createElement('li');
					listItem.className = 'result-item';

					const link = document.createElement('a');
					link.href = getPostHref(item.s);

					const category = document.createElement('span');
					category.className = 'result-category';
					category.textContent = getCategoryLabel(item.c);

					const title = document.createElement('h3');
					title.textContent = item.t;

					const description = document.createElement('p');
					description.textContent = item.d || item.e || '';

					link.append(category, title, description);
					if (snippet && snippet !== description.textContent) {
						const snippetElement = document.createElement('p');
						snippetElement.className = 'result-snippet';
						appendHighlightedText(snippetElement, snippet, searchInput?.value.trim() ?? '');
						link.append(snippetElement);
					}
					listItem.append(link);

					return listItem;
				});

				resultsList.replaceChildren(...resultItems);
			}

			function appendHighlightedText(parent: HTMLElement, text: string, query: string) {
				const normalizedQuery = query.toLowerCase();
				const normalizedText = text.toLowerCase();
				const index = normalizedQuery ? normalizedText.indexOf(normalizedQuery) : -1;

				if (index === -1) {
					parent.textContent = text;
					return;
				}

				parent.append(
					document.createTextNode(text.slice(0, index)),
					Object.assign(document.createElement('mark'), {
						textContent: text.slice(index, index + query.length),
					}),
					document.createTextNode(text.slice(index + query.length)),
				);
			}
		</script>
	</body>
</html>
