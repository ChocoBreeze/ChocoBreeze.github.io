---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.data.slug || post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;
type BlogCategory = CollectionEntry<'blog'>['data']['categories'];

const post = Astro.props;
const { Content, headings } = await render(post);

// "이전/다음 글" 찾기 로직
const allPosts = (await getCollection('blog')).filter(p => {
	const currentCats = post.data.categories;
	const pCats = p.data.categories;
	const normalize = (c: BlogCategory) => {
		if (Array.isArray(c)) return c[0];
		return c;
	};
	return normalize(currentCats) === normalize(pCats);
}).sort((a, b) => {
	// ETF 카테고리인 경우 (대소문자 무시)
	const isETF = (c: BlogCategory) => {
		const norm = Array.isArray(c) ? c[0] : c;
		return norm?.toLowerCase() === 'etf';
	};

	if (isETF(a.data.categories)) {
		// 1. Pinned 우선
		if (a.data.pinned && !b.data.pinned) return -1;
		if (!a.data.pinned && b.data.pinned) return 1;
		
		// 2. Order 순서 (order가 없으면 아주 큰 숫자 부여)
		const orderA = a.data.order ?? 999;
		const orderB = b.data.order ?? 999;
		if (orderA !== orderB) return orderA - orderB;
	}

	// 그 외 일반 글들은 날짜 순 (과거 -> 최신 순으로 정렬해야 '다음 글'이 미래 글이 됨)
	const dateA = a.data.pubDate || a.data.date || new Date(0);
	const dateB = b.data.pubDate || b.data.date || new Date(0);
	return dateA.valueOf() - dateB.valueOf(); 
});

const index = allPosts.findIndex((p) => p.id === post.id);
const prevPost = index > 0 ? allPosts[index - 1] : null;
const nextPost = index < allPosts.length - 1 ? allPosts[index + 1] : null;

const getSlug = (p: CollectionEntry<'blog'>) => p.data.slug || p.id;
---

<BlogPost {...post.data} headings={headings}>
	<Content />
	
	<div class="post-navigation">
		{prevPost && (
			<a href={`/blog/${getSlug(prevPost)}/`} class="prev">
				<span class="label">← 이전 글</span>
				<span class="title">{prevPost.data.title}</span>
			</a>
		)}
		{!prevPost && <div class="spacer"></div>}
		
		{nextPost && (
			<a href={`/blog/${getSlug(nextPost)}/`} class="next">
				<span class="label">다음 글 →</span>
				<span class="title">{nextPost.data.title}</span>
			</a>
		)}
	</div>
</BlogPost>

<style>
	.post-navigation {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border-color);
	}
	.post-navigation a {
		flex: 1;
		display: flex;
		flex-direction: column;
		padding: 1rem;
		border: 1px solid var(--border-color);
		border-radius: 8px;
		text-decoration: none;
		color: var(--text-color);
		background: var(--card-bg);
		transition: all 0.2s ease;
		max-width: 50%;
	}
	.post-navigation a:hover {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--card-bg) 82%, var(--muted-text) 18%);
	}
	.post-navigation .label {
		font-size: 0.8rem;
		color: var(--muted-text);
		margin-bottom: 0.25rem;
	}
	.post-navigation .title {
		font-weight: bold;
		color: var(--heading-color);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.post-navigation .next {
		text-align: right;
	}
	.spacer {
		flex: 1;
	}
</style>
