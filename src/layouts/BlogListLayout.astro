---
import BaseHead from '../components/BaseHead.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import type { CollectionEntry } from 'astro:content';
import type { BlogCategoryKey } from '../data/blogCategories';

type Props = {
	title: string;
	description: string;
	activeCategory: BlogCategoryKey;
	posts: CollectionEntry<'blog'>[];
};

const { title, description, activeCategory, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="blog-page-shell">
			<BlogSidebar activeCategory={activeCategory} />
			<section class="blog-list-panel">
				<div class="blog-list-heading">
					<p class="blog-list-eyebrow">Archive</p>
					<h1>{title}</h1>
					<p>{description}</p>
				</div>
				<ul class="blog-post-grid">
					{posts.map((post) => <BlogPostCard post={post} />)}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
