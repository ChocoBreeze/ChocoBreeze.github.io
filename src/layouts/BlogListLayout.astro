---
import BaseHead from '../components/BaseHead.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import type { CollectionEntry } from 'astro:content';
import { BLOG_CATEGORIES, type BlogCategoryKey } from '../data/blogCategories';
import { getCategoryFeedPath } from '../lib/rss';

type Props = {
	title: string;
	description: string;
	activeCategory: BlogCategoryKey;
	posts: CollectionEntry<'blog'>[];
};

const { title, description, activeCategory, posts } = Astro.props;
const category = BLOG_CATEGORIES.find(({ key }) => key === activeCategory);
const rssHref = getCategoryFeedPath(activeCategory);

const pinnedPosts = posts.filter((p) => p.data.pinned);
const regularPosts = posts.filter((p) => !p.data.pinned);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			rssHref={rssHref}
			rssTitle={category ? `${category.title} RSS` : undefined}
		/>
	</head>
	<body>
		<Header />
		<main id="main-content" class="blog-page-shell">
			<BlogSidebar activeCategory={activeCategory} />
			<section class="blog-list-panel">
				<div class="blog-list-heading">
					<p class="blog-list-eyebrow">Archive</p>
					<h1>{title}</h1>
					<p>{description}</p>
					{
						rssHref && (
							<a class="rss-subscribe-link" href={rssHref}>
								<span aria-hidden="true">RSS</span>
								<span>이 카테고리 구독</span>
							</a>
						)
					}
				</div>
				<slot />
				{
					pinnedPosts.length > 0 && (
						<div class="pinned-section">
							<p class="pinned-label">
								<svg
									viewBox="0 0 24 24"
									width="13"
									height="13"
									fill="currentColor"
									aria-hidden="true"
								>
									<path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z" />
								</svg>
								시작 가이드
							</p>
							<ul class="blog-post-grid">
								{pinnedPosts.map((post) => (
									<BlogPostCard post={post} />
								))}
							</ul>
						</div>
					)
				}
				{
					regularPosts.length > 0 && (
						<>
							<div class="sort-controls">
								<span class="sort-label">정렬</span>
								<div class="sort-btn-group" role="group" aria-label="정렬 순서">
									<button class="sort-btn active" data-sort="desc" aria-pressed="true">
										최신순
									</button>
									<button class="sort-btn" data-sort="asc" aria-pressed="false">
										오래된 순
									</button>
								</div>
							</div>
							<ul class="blog-post-grid regular-post-grid">
								{regularPosts.map((post) => (
									<BlogPostCard post={post} />
								))}
							</ul>
							<button class="load-more-btn" type="button" hidden>
								더 보기
							</button>
						</>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.rss-subscribe-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1rem;
		padding: 0.55rem 0.85rem;
		border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--border-color));
		border-radius: var(--nv-radius-sm);
		background: color-mix(in srgb, var(--card-bg) 86%, var(--accent) 14%);
		color: var(--heading-color);
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.rss-subscribe-link:hover {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--card-bg) 74%, var(--accent) 26%);
		transform: translateY(-1px);
	}

	.rss-subscribe-link:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--accent) 45%, transparent);
		outline-offset: 4px;
	}

	.pinned-section {
		margin-bottom: 0.5rem;
	}

	.pinned-label {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin: 0 0 1rem;
		padding: 0.25rem 0.6rem;
		border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--border-color));
		border-radius: var(--nv-radius-sm);
		background: color-mix(in srgb, var(--card-bg) 82%, var(--accent) 18%);
		color: var(--accent);
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.07em;
	}

	.sort-controls {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 2rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border-color);
	}

	.sort-label {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--muted-text);
		font-weight: 700;
	}

	.sort-btn-group {
		display: flex;
		border: 1px solid var(--border-color);
		border-radius: var(--nv-radius-sm);
		overflow: hidden;
	}

	.sort-btn {
		padding: 0.38rem 0.9rem;
		border: none;
		border-right: 1px solid var(--border-color);
		background: transparent;
		color: var(--muted-text);
		font-size: 0.82rem;
		font-weight: 600;
		cursor: pointer;
		font-family: inherit;
		line-height: 1.4;
		transition:
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.sort-btn:last-child {
		border-right: none;
	}

	.sort-btn:hover:not(.active) {
		background: color-mix(in srgb, var(--card-bg) 75%, var(--muted-text) 25%);
		color: var(--text-color);
	}

	.sort-btn.active {
		background: var(--nv-primary);
		color: #000000;
		font-weight: 700;
	}

	.sort-btn:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--accent) 45%, transparent);
		outline-offset: 2px;
		position: relative;
		z-index: 1;
	}

	/* Applied by JS only, so no-JS visitors still see every post. */
	.regular-post-grid > li.is-hidden {
		display: none;
	}

	.load-more-btn {
		display: block;
		width: 100%;
		margin-top: 2rem;
		padding: 0.85rem 1rem;
		border: 1px solid var(--border-color);
		border-radius: var(--nv-radius-sm);
		background: var(--card-bg);
		color: var(--heading-color);
		font-size: 0.92rem;
		font-weight: 700;
		font-family: inherit;
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.load-more-btn:hover {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--card-bg) 80%, var(--accent) 20%);
	}

	.load-more-btn:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--accent) 45%, transparent);
		outline-offset: 2px;
	}
</style>

<script>
	const PAGE_SIZE = 30;
	const grid = document.querySelector('.regular-post-grid');
	const buttons = document.querySelectorAll<HTMLButtonElement>('.sort-btn');
	const loadMoreBtn = document.querySelector<HTMLButtonElement>('.load-more-btn');

	const itemData = grid
		? [...grid.querySelectorAll<HTMLLIElement>('li[data-pub-date]')].map((el) => ({
				el,
				t: parseInt(el.dataset.pubDate ?? '0'),
			}))
		: [];

	// How many posts are currently revealed; persists across sort changes so
	// re-sorting keeps the same amount of content on screen (just reordered).
	let shownCount = Math.min(PAGE_SIZE, itemData.length);

	function applyVisibility() {
		itemData.forEach(({ el }, index) => {
			el.classList.toggle('is-hidden', index >= shownCount);
		});

		if (loadMoreBtn) {
			const remaining = itemData.length - shownCount;
			loadMoreBtn.hidden = remaining <= 0;
			loadMoreBtn.textContent = remaining > 0 ? `더 보기 (${remaining}개 남음)` : '더 보기';
		}
	}

	function sortGrid(order: 'asc' | 'desc', historyMode: 'push' | 'replace' = 'push') {
		if (!grid) return;

		itemData.sort((a, b) => (order === 'asc' ? a.t - b.t : b.t - a.t));
		itemData.forEach(({ el }) => grid.appendChild(el));
		applyVisibility();

		buttons.forEach((btn) => {
			const isActive = btn.dataset.sort === order;
			btn.classList.toggle('active', isActive);
			btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
		});

		const url = new URL(window.location.href);
		order === 'desc' ? url.searchParams.delete('sort') : url.searchParams.set('sort', order);
		if (historyMode === 'replace') {
			window.history.replaceState({}, '', url.toString());
		} else {
			window.history.pushState({}, '', url.toString());
		}
	}

	const rawSort = new URLSearchParams(window.location.search).get('sort');
	const initialSort: 'asc' | 'desc' = rawSort === 'asc' ? 'asc' : 'desc';

	sortGrid(initialSort, 'replace');

	window.addEventListener('popstate', () => {
		const sort = new URLSearchParams(window.location.search).get('sort');
		sortGrid(sort === 'asc' ? 'asc' : 'desc', 'replace');
	});

	buttons.forEach((btn) =>
		btn.addEventListener('click', () => {
			sortGrid(btn.dataset.sort === 'asc' ? 'asc' : 'desc');
		}),
	);

	loadMoreBtn?.addEventListener('click', () => {
		shownCount = Math.min(shownCount + PAGE_SIZE, itemData.length);
		applyVisibility();
	});
</script>
