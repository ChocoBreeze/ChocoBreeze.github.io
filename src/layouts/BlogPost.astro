---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCategoryDefinition } from '../data/blogCategories';

type BlogPostData = CollectionEntry<'blog'>['data'];

type Props = Pick<
	BlogPostData,
	| 'title'
	| 'description'
	| 'pubDate'
	| 'date'
	| 'updatedDate'
	| 'heroImage'
	| 'image'
	| 'categories'
	| 'difficulty'
	| 'topics'
> & {
	headings?: MarkdownHeading[];
	ogImage?: string;
};

const {
	title,
	description,
	pubDate,
	date: jekyllDate,
	updatedDate,
	heroImage,
	image: jekyllImage,
	difficulty,
	topics,
	headings,
	ogImage,
} = Astro.props;
const date = pubDate || jekyllDate;
const image = heroImage || (jekyllImage ? `/images/${jekyllImage}` : undefined);
// The on-page hero uses only a real image; the social card falls back to the
// generated OG image when the post has none.
const socialImage = image ?? ogImage;
const activeCategory = getCategoryDefinition(Astro.props.categories)?.key;
const visibleTopics = topics?.slice(0, 6) ?? [];
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={socialImage}
			type="article"
			publishedTime={date}
			modifiedTime={updatedDate}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 1rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: var(--nv-radius-sm);
				max-width: 720px;
				height: auto;
				border: 1px solid var(--border-color);
			}
			.blog-post-shell {
				width: min(1560px, calc(100% - 2em));
				margin: 2rem auto;
				display: grid;
				grid-template-columns: 240px minmax(0, 1fr) 240px;
				gap: 2rem;
				align-items: start;
			}
			.prose {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 1em;
				color: var(--text-color);
				position: relative;
			}
			.prose :global(img) {
				display: block;
				width: auto;
				max-width: min(100%, 960px);
				max-height: 72vh;
				margin: 1.75rem auto 0.75rem;
				border: 1px solid var(--border-color);
				border-radius: var(--nv-radius-sm);
				background: var(--card-bg);
			}
			.prose :global(img[data-expandable-image]) {
				cursor: zoom-in;
				transition: border-color 0.2s ease;
			}
			.prose :global(img[data-expandable-image]:hover),
			.prose :global(img[data-expandable-image]:focus-visible) {
				border-color: var(--accent);
				outline: none;
			}
			.image-lightbox {
				position: fixed;
				inset: 0;
				z-index: 10000;
				display: none;
				align-items: center;
				justify-content: center;
				padding: 2rem;
				background: rgba(0, 0, 0, 0.88);
			}
			.image-lightbox.is-open {
				display: flex;
			}
			.image-lightbox img {
				max-width: min(100%, 1200px);
				max-height: 86vh;
				border-radius: var(--nv-radius-sm);
				border: 1px solid var(--nv-hairline-strong);
				background: var(--nv-surface-dark);
			}
			.image-lightbox button {
				position: absolute;
				top: 1.25rem;
				right: 1.25rem;
				width: 44px;
				height: 44px;
				border: 1px solid rgba(255, 255, 255, 0.35);
				border-radius: var(--nv-radius-sm);
				background: rgba(0, 0, 0, 0.5);
				color: #fff;
				cursor: pointer;
				font-size: 1.5rem;
				line-height: 1;
			}
			.image-lightbox button:hover,
			.image-lightbox button:focus-visible {
				background: rgba(0, 0, 0, 0.7);
				outline: 2px solid var(--nv-primary);
				outline-offset: 2px;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: left;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--muted-text);
			}
			.last-updated-on {
				font-style: italic;
			}
			.post-meta-chips {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				margin: 0.8rem 0 0;
			}
			.post-meta-chip {
				display: inline-flex;
				align-items: center;
				width: fit-content;
				padding: 0.24rem 0.58rem;
				border: 1px solid color-mix(in srgb, var(--border-color) 80%, var(--accent) 20%);
				border-radius: var(--nv-radius-sm);
				background: var(--nv-surface-soft);
				color: var(--heading-color);
				font-size: 0.78rem;
				font-weight: 700;
				line-height: 1.2;
			}
			:global([data-theme='dark']) .post-meta-chip {
				background: #2a2a2a;
			}
			.post-meta-chip[data-difficulty='easy'] {
				background: color-mix(in srgb, #2da44e 16%, var(--card-bg));
				border-color: color-mix(in srgb, #2da44e 36%, var(--border-color));
			}
			.post-meta-chip[data-difficulty='medium'] {
				background: color-mix(in srgb, #bf8700 16%, var(--card-bg));
				border-color: color-mix(in srgb, #bf8700 36%, var(--border-color));
			}
			.post-meta-chip[data-difficulty='hard'] {
				background: color-mix(in srgb, #cf222e 14%, var(--card-bg));
				border-color: color-mix(in srgb, #cf222e 34%, var(--border-color));
			}

			/* Table of Contents Styles */
			.toc {
				position: sticky;
				top: 110px;
				width: 100%;
				max-height: min(40rem, calc(100vh - 160px));
				overflow: hidden;
				padding: 1.1rem;
				font-size: 0.88rem;
				border: 1px solid var(--border-color);
				border-radius: var(--nv-radius-sm);
				background: var(--toc-bg);
				display: none;
			}
			@media (min-width: 1400px) {
				.toc {
					display: block;
				}
			}
			.toc h2 {
				font-size: 0.78rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				margin-top: 0;
				margin-bottom: 0.9rem;
				color: var(--muted-text);
			}
			.toc ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.45rem;
				max-height: calc(min(40rem, 100vh - 160px) - 3.2rem);
				overflow-y: auto;
				overscroll-behavior: contain;
				padding-right: 0.25rem;
				scrollbar-width: thin;
				scrollbar-color: color-mix(in srgb, var(--muted-text) 45%, transparent) transparent;
			}
			.toc ul::-webkit-scrollbar {
				width: 6px;
			}
			.toc ul::-webkit-scrollbar-thumb {
				background: color-mix(in srgb, var(--muted-text) 45%, transparent);
				border-radius: 999px;
			}
			.toc li {
				margin-bottom: 0;
				line-height: 1.35;
			}
			.toc a {
				display: block;
				padding: 0.7rem 0.85rem;
				border-radius: var(--nv-radius-sm);
				text-decoration: none;
				color: var(--text-color);
				border: 1px solid transparent;
				background: transparent;
				transition:
					background-color 0.2s ease,
					border-color 0.2s ease;
			}
			.toc a:hover {
				color: var(--accent);
				background: color-mix(in srgb, var(--card-bg) 82%, var(--muted-text) 18%);
				border-color: var(--border-color);
			}
			.toc a.active {
				color: var(--heading-color);
				background: color-mix(in srgb, var(--accent) 10%, transparent);
				border-color: var(--accent);
				font-weight: 700;
			}
			.toc .depth-3 {
				margin-left: 0.9rem;
			}

			/* Back to Top Button */
			#back-to-top {
				position: fixed;
				bottom: 3rem;
				right: 3rem;
				width: 50px;
				height: 50px;
				background-color: var(--nv-primary);
				color: var(--nv-on-primary);
				border: none;
				border-radius: var(--nv-radius-sm);
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				opacity: 0;
				visibility: hidden;
				transition:
					opacity 0.3s ease,
					visibility 0.3s ease,
					background-color 0.2s ease;
				z-index: 9999;
			}
			#back-to-top.show {
				opacity: 1;
				visibility: visible;
			}
			#back-to-top:hover {
				background-color: var(--nv-primary-dark);
			}
			@media (max-width: 1399px) {
				.blog-post-shell {
					grid-template-columns: 240px minmax(0, 1fr);
				}
			}
			@media (max-width: 980px) {
				main {
					width: 100%;
				}
				.blog-post-shell {
					grid-template-columns: 1fr;
					width: min(100%, calc(100% - 1.25rem));
					margin: 1rem auto 1.5rem;
					gap: 1.25rem;
				}
				.prose {
					order: 1;
					padding: 0.75rem 0;
					min-width: 0;
				}
				.prose :global(img) {
					max-height: none;
					margin: 1.25rem auto 0.5rem;
					border-radius: var(--nv-radius-sm);
				}
				.blog-post-shell :global(.blog-sidebar) {
					order: 2;
					position: static;
				}
				.blog-post-shell :global(.blog-sidebar-inner) {
					max-height: 16rem;
					overflow-y: auto;
					overscroll-behavior: contain;
				}
				.title {
					padding: 0.25rem 0 0.75rem;
					margin-bottom: 0.5rem;
				}
				.title h1 {
					font-size: clamp(1.8rem, 8vw, 2.4rem);
					line-height: 1.15;
					overflow-wrap: anywhere;
				}
				.hero-image {
					margin-bottom: 0;
				}
				#back-to-top {
					right: 1.25rem;
					bottom: 1.25rem;
					width: 44px;
					height: 44px;
				}
			}
			@media (max-width: 520px) {
				.blog-post-shell {
					width: min(100%, calc(100% - 1rem));
				}
				.prose {
					padding: 0.25rem 0;
				}
				.hero-image img {
					border-radius: 0 0 12px 12px;
				}
				.image-lightbox {
					padding: 0.75rem;
				}
				.image-lightbox img {
					max-height: 82vh;
					border-radius: var(--nv-radius-sm);
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main id="main-content">
			<article>
				<div class="hero-image">
					{image && <img width={1020} height={510} src={image} alt="" />}
				</div>
				<div class="blog-post-shell">
					<BlogSidebar activeCategory={activeCategory} />
					<div class="prose">
						<div class="title">
							<div class="date">
								{date && <FormattedDate date={date} />}
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							{
								(difficulty || visibleTopics.length > 0) && (
									<div class="post-meta-chips" aria-label="Post metadata">
										{difficulty && (
											<span class="post-meta-chip" data-difficulty={difficulty.toLowerCase()}>
												난이도: {difficulty}
											</span>
										)}
										{visibleTopics.map((topic) => (
											<span class="post-meta-chip">{topic}</span>
										))}
									</div>
								)
							}
							<hr />
						</div>
						<slot />
					</div>
					{
						headings && headings.length > 0 && (
							<nav class="toc">
								<h2>On this page</h2>
								<ul>
									{headings
										.filter((h) => h.depth <= 3 && h.text.trim().toLowerCase() !== 'footnotes')
										.map((h) => (
											<li class={`depth-${h.depth}`}>
												<a href={`#${h.slug}`}>{h.text}</a>
											</li>
										))}
								</ul>
							</nav>
						)
					}
				</div>
			</article>
		</main>

		<button id="back-to-top" aria-label="Back to top">
			<svg
				viewBox="0 0 24 24"
				width="24"
				height="24"
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<polyline points="18 15 12 9 6 15"></polyline>
			</svg>
		</button>

		<div class="image-lightbox" id="image-lightbox" aria-hidden="true">
			<button type="button" aria-label="Close image preview">×</button>
			<img alt="" />
		</div>

		<Footer />

		<script>
			const backToTop = document.getElementById('back-to-top');
			const imageLightbox = document.getElementById('image-lightbox');
			const lightboxImage = imageLightbox?.querySelector('img');
			const lightboxClose = imageLightbox?.querySelector('button');
			const tocLinks = Array.from(document.querySelectorAll('.toc a'));
			const headingElements: { link: Element; element: HTMLElement }[] = [];

			for (const link of tocLinks) {
				const id = link.getAttribute('href')?.slice(1);
				if (!id) continue;

				const element = document.getElementById(id);
				if (!element) continue;

				headingElements.push({ link, element });
			}

			window.addEventListener('scroll', () => {
				if (!backToTop) return;

				if (window.scrollY > 300) {
					backToTop.classList.add('show');
				} else {
					backToTop.classList.remove('show');
				}
			});

			if (backToTop) {
				backToTop.addEventListener('click', () => {
					window.scrollTo({
						top: 0,
						behavior: 'smooth',
					});
				});
			}

			const closeImageLightbox = () => {
				imageLightbox?.classList.remove('is-open');
				imageLightbox?.setAttribute('aria-hidden', 'true');
				document.body.style.overflow = '';
			};

			const openImageLightbox = (image: HTMLImageElement) => {
				if (!imageLightbox || !lightboxImage) return;

				lightboxImage.src = image.currentSrc || image.src;
				lightboxImage.alt = image.alt;
				imageLightbox.classList.add('is-open');
				imageLightbox.setAttribute('aria-hidden', 'false');
				document.body.style.overflow = 'hidden';
				lightboxClose?.focus();
			};

			document.querySelectorAll<HTMLImageElement>('.prose img').forEach((image) => {
				image.dataset.expandableImage = 'true';
				image.tabIndex = 0;
				image.setAttribute('role', 'button');
				image.setAttribute('aria-label', image.alt ? `${image.alt} 이미지 확대` : '이미지 확대');

				image.addEventListener('click', () => openImageLightbox(image));
				image.addEventListener('keydown', (event) => {
					if (event.key === 'Enter' || event.key === ' ') {
						event.preventDefault();
						openImageLightbox(image);
					}
				});
			});

			lightboxClose?.addEventListener('click', closeImageLightbox);
			imageLightbox?.addEventListener('click', (event) => {
				if (event.target === imageLightbox) {
					closeImageLightbox();
				}
			});
			window.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeImageLightbox();
				}
			});

			if (headingElements.length > 0) {
				let currentActiveId = '';

				const setActiveLink = (activeId: string) => {
					if (currentActiveId === activeId) return;
					currentActiveId = activeId;

					headingElements.forEach(({ link, element }) => {
						const isActive = element.id === activeId;
						link.classList.toggle('active', isActive);
						link.setAttribute('aria-current', isActive ? 'true' : 'false');

						if (isActive) {
							link.scrollIntoView({
								block: 'nearest',
								inline: 'nearest',
							});
						}
					});
				};

				const observer = new IntersectionObserver(
					(entries) => {
						const visibleEntries = entries
							.filter((entry) => entry.isIntersecting)
							.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

						if (visibleEntries.length > 0) {
							setActiveLink(visibleEntries[0].target.id);
							return;
						}

						const passedHeadings = headingElements
							.filter(({ element }) => element.getBoundingClientRect().top <= 160)
							.map(({ element }) => element.id);

						if (passedHeadings.length > 0) {
							setActiveLink(passedHeadings[passedHeadings.length - 1]);
						}
					},
					{
						rootMargin: '-120px 0px -55% 0px',
						threshold: [0, 1],
					},
				);

				headingElements.forEach(({ element }) => observer.observe(element));
				setActiveLink(headingElements[0].element.id);
			}
		</script>
	</body>
</html>
