---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import BlogSidebar from "../components/BlogSidebar.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { getCategoryDefinition } from "../data/blogCategories";

type Props = CollectionEntry<"blog">["data"];

const {
    title,
    description,
    pubDate,
    date: jekyllDate,
    updatedDate,
    heroImage,
    image: jekyllImage,
    headings,
} = Astro.props;
const date = pubDate || jekyllDate;
const image = heroImage || (jekyllImage ? `/images/${jekyllImage}` : undefined);
const activeCategory = getCategoryDefinition(Astro.props.categories)?.key;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            main {
                width: calc(100% - 2em);
                max-width: 100%;
                margin: 0;
            }
            .hero-image {
                width: 100%;
                margin-bottom: 1rem;
            }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: var(--box-shadow);
                max-width: 720px; /* 이미지 너비를 720px로 제한 */
                height: auto;
            }
            .blog-post-shell {
                width: min(1560px, calc(100% - 2em));
                margin: 2rem auto;
                display: grid;
                grid-template-columns: 240px minmax(0, 1fr) 240px;
                gap: 2rem;
                align-items: start;
            }
            .prose {
                width: 100%;
                max-width: 100%;
                margin: 0;
                padding: 1em;
                color: var(--text-color);
                position: relative;
            }
            .title {
                margin-bottom: 1em;
                padding: 1em 0;
                text-align: left;
                line-height: 1;
            }
            .title h1 {
                margin: 0 0 0.5em 0;
            }
            .date {
                margin-bottom: 0.5em;
                color: var(--muted-text);
            }
            .last-updated-on {
                font-style: italic;
            }

            /* Table of Contents Styles */
            .toc {
                position: sticky;
                top: 110px;
                width: 100%;
                max-height: min(40rem, calc(100vh - 160px));
                overflow: hidden;
                padding: 1.1rem;
                font-size: 0.88rem;
                border: 1px solid var(--border-color);
                border-radius: 20px;
                background: var(--toc-bg);
                box-shadow: 0 12px 30px rgba(var(--gray), 0.12);
                backdrop-filter: blur(14px);
                display: none;
            }
            @media (min-width: 1400px) {
                .toc {
                    display: block;
                }
            }
            .toc h2 {
                font-size: 0.78rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.12em;
                margin-top: 0;
                margin-bottom: 0.9rem;
                color: var(--muted-text);
            }
            .toc ul {
                list-style: none;
                padding: 0;
                margin: 0;
                display: grid;
                gap: 0.45rem;
                max-height: calc(min(40rem, 100vh - 160px) - 3.2rem);
                overflow-y: auto;
                overscroll-behavior: contain;
                padding-right: 0.25rem;
                scrollbar-width: thin;
                scrollbar-color: color-mix(in srgb, var(--muted-text) 45%, transparent) transparent;
            }
            .toc ul::-webkit-scrollbar {
                width: 6px;
            }
            .toc ul::-webkit-scrollbar-thumb {
                background: color-mix(in srgb, var(--muted-text) 45%, transparent);
                border-radius: 999px;
            }
            .toc li {
                margin-bottom: 0;
                line-height: 1.35;
            }
            .toc a {
                display: block;
                padding: 0.7rem 0.85rem;
                border-radius: 14px;
                text-decoration: none;
                color: var(--text-color);
                border: 1px solid transparent;
                background: transparent;
                transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
            }
            .toc a:hover {
                color: var(--accent);
                background: color-mix(in srgb, var(--card-bg) 82%, var(--muted-text) 18%);
                border-color: var(--border-color);
                transform: translateX(2px);
            }
            .toc a.active {
                color: var(--heading-color);
                background: color-mix(in srgb, var(--accent) 12%, transparent);
                border-color: color-mix(in srgb, var(--accent) 30%, var(--border-color));
                font-weight: 700;
            }
            .toc .depth-3 {
                margin-left: 0.9rem;
            }

            /* Back to Top Button */
            #back-to-top {
                position: fixed;
                bottom: 3rem;
                right: 3rem;
                width: 50px;
                height: 50px;
                background-color: var(--accent); /* 기본 색상을 강조색으로 */
                color: white;
                border: none;
                border-radius: 50%;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
                opacity: 0;
                visibility: hidden;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                z-index: 9999; /* 최상단으로 */
            }
            #back-to-top.show {
                opacity: 1;
                visibility: visible;
            }
            #back-to-top:hover {
                transform: translateY(-5px);
                box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
            }
            @media (max-width: 1399px) {
                .blog-post-shell {
                    grid-template-columns: 240px minmax(0, 1fr);
                }
            }
            @media (max-width: 980px) {
                .blog-post-shell {
                    grid-template-columns: 1fr;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {
                        image && (
                            <img width={1020} height={510} src={image} alt="" />
                        )
                    }
                </div>
                <div class="blog-post-shell">
                    <BlogSidebar activeCategory={activeCategory} />
                    <div class="prose">
                        <div class="title">
                            <div class="date">
                                {date && <FormattedDate date={date} />}
                                {
                                    updatedDate && (
                                        <div class="last-updated-on">
                                            Last updated on{" "}
                                            <FormattedDate date={updatedDate} />
                                        </div>
                                    )
                                }
                            </div>
                            <h1>{title}</h1>
                            <hr />
                        </div>
                        <slot />
                    </div>
                    {
                        headings && headings.length > 0 && (
                            <nav class="toc">
                                <h2>On this page</h2>
                                <ul>
                                    {headings
                                        .filter(
                                            (h) =>
                                                h.depth <= 3 &&
                                                h.text.trim().toLowerCase() !== "footnotes"
                                        )
                                        .map((h) => (
                                            <li class={`depth-${h.depth}`}>
                                                <a href={`#${h.slug}`}>
                                                    {h.text}
                                                </a>
                                            </li>
                                        ))}
                                </ul>
                            </nav>
                        )
                    }
                </div>
            </article>
        </main>

        <button id="back-to-top" aria-label="Back to top">
            <svg
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <polyline points="18 15 12 9 6 15"></polyline>
            </svg>
        </button>

        <Footer />

        <script>
            const backToTop = document.getElementById("back-to-top");
            const tocLinks = Array.from(document.querySelectorAll(".toc a"));
            const headingElements = tocLinks
                .map((link) => {
                    const id = link.getAttribute("href")?.slice(1);
                    if (!id) return null;

                    const element = document.getElementById(id);
                    if (!element) return null;

                    return { link, element };
                })
                .filter(Boolean);

            window.addEventListener("scroll", () => {
                if (window.scrollY > 300) {
                    backToTop.classList.add("show");
                } else {
                    backToTop.classList.remove("show");
                }
            });

            backToTop.addEventListener("click", () => {
                window.scrollTo({
                    top: 0,
                    behavior: "smooth",
                });
            });

            if (headingElements.length > 0) {
                const setActiveLink = (activeId) => {
                    headingElements.forEach(({ link, element }) => {
                        const isActive = element.id === activeId;
                        link.classList.toggle("active", isActive);
                        link.setAttribute("aria-current", isActive ? "true" : "false");
                    });
                };

                const observer = new IntersectionObserver(
                    (entries) => {
                        const visibleEntries = entries
                            .filter((entry) => entry.isIntersecting)
                            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

                        if (visibleEntries.length > 0) {
                            setActiveLink(visibleEntries[0].target.id);
                            return;
                        }

                        const passedHeadings = headingElements
                            .filter(({ element }) => element.getBoundingClientRect().top <= 160)
                            .map(({ element }) => element.id);

                        if (passedHeadings.length > 0) {
                            setActiveLink(passedHeadings[passedHeadings.length - 1]);
                        }
                    },
                    {
                        rootMargin: "-120px 0px -55% 0px",
                        threshold: [0, 1],
                    }
                );

                headingElements.forEach(({ element }) => observer.observe(element));
                setActiveLink(headingElements[0].element.id);
            }
        </script>
    </body>
</html>
